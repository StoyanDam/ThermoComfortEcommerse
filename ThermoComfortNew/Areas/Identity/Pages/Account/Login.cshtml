@page
@model LoginModel

@{
    ViewData["Title"] = "Вход в профила";
}

<head>  <link href="~/css/site.css" rel="stylesheet" /></head>
<div class="row d-flex justify-content-center align-items-center text-center form-holder">

    <div class="col-md-4">
        <h2>@ViewData["Title"]</h2>
        <section >
            <form id="account" method="post">
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.NickName" class="form-control" autocomplete="username" aria-required="true" placeholder="name" />
                    <label asp-for="Input.NickName" class="form-label">Потребителско име</label>
                    <span asp-validation-for="Input.NickName" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Парола</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-success">Вход</button>
                </div>
                <div>
                  
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Регистрирай се</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
   
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
