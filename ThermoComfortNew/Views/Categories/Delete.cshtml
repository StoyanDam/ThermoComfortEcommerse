@model ThermoComfortNew.Domain.Category

@{
    ViewData["Title"] = "Изтриване на категория";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0"><i class="fas fa-trash-alt"></i> @ViewData["Title"]</h3>
        </div>
        <div class="card-body">
            <h5 class="text-danger">Сигурни ли сте, че искате да изтриете тази категория?</h5>
            <hr />

            <div class="row">
                <div class="col-md-6">
                    <strong>Категория:</strong>
                </div>
                <div class="col-md-6">
                    @Model.CategoryName
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-6">
                    <strong>Описание:</strong>
                </div>
                <div class="col-md-6">
                    @Model.Description
                </div>
            </div>

            <hr />
            <form method="post" asp-action="Delete">
                <input type="hidden" asp-for="CategoryID" />

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="fas fa-trash-alt"></i> Изтрий
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Назад към списъка
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
