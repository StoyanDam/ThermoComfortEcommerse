 @model ThermoComfortNew.Domain.Category

@{
    ViewData["Title"] = "Изтриване на категория";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-danger text-white">
            <h4><i class="bi bi-trash"></i> Потвърдете изтриването</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Внимание!</strong> Сигурни ли сте, че искате да изтриете тази категория? Това действие не може да бъде отменено.
            </div>

            <dl class="row">
                <dt class="col-sm-3 fw-bold">Категория:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryName)</dd>

                <dt class="col-sm-3 fw-bold">Описание:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="CategoryID" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Назад към списъка
                    </a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Изтрий
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
