
 @model ThermoComfort.Data.Models.Product

@{
    ViewData["Title"] = "Детайли за продукта";
}

<div class="container mt-5">
    <div class="row">

        <div class="col-md-5">
            <img src="@Url.Content("~/images/" + Model.ImageUrl)" alt="Product Image" class="img-fluid rounded">
        </div>


        <div class="col-md-7">
            <div class="p-4 bg-white rounded shadow">
                <h2 class="text-primary">@Model.ProductName</h2>
                <p class="text-muted">Категория: <strong>@Model.Category.CategoryName</strong></p>
                <h4 class="text-success">Цена: @Model.Price лв</h4>
                <p><strong>Наличност:</strong> @Model.Availability</p>
                <p><strong>Описание:</strong> @Model.Description</p>
                <p><strong>Характеристики:</strong> @Model.Characteristics</p>
                <p><strong>Марка:</strong> @Model.Brand</p>
                <p><small class="text-muted">Създадено на: @Model.CreatedOn</small></p>

     
                <div class="d-flex gap-3 mt-3">
                    <a asp-action="All" class="btn btn-outline-primary">Назад</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-secondary">Редактиране</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
