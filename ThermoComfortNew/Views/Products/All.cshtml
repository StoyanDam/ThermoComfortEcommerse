@model IEnumerable<ThermoComfort.Data.Models.Product>

@{
    ViewData["Title"] = "Всички продукти";
}

<h2 class="text-center">Всички продукти</h2>

<form method="get" asp-action="All" class="mb-3">
    <div class="input-group mb-3">
        <input type="text" name="searchTerm" class="form-control" placeholder="Търсене по име..." value="@Context.Request.Query["searchTerm"]" />
        <button type="submit" class="btn btn-primary">Търси</button>
    </div>

    <div class="form-group">
        <label for="categoryId">Категория:</label>
        <div class="input-group">
            <select id="categoryId" name="categoryId" class="form-control">
                <option value="">Всички</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var category in ViewBag.Categories)
                    {
                        <option value="@category.CategoryID"
                                selected="@(ViewBag.SelectedCategory == category.CategoryID ? "selected" : null)">
                            @category.CategoryName
                        </option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-success">Филтрирай</button>
        </div>
    </div>
</form>

<!-- Сортиране -->
<div class="mb-3 text-center">
    <a asp-action="All" asp-route-sortOrder="price_asc" class="btn btn-outline-secondary">Сортирай по цена ↑</a>
    <a asp-action="All" asp-route-sortOrder="price_desc" class="btn btn-outline-secondary">Сортирай по цена ↓</a>
</div>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">
                <img class="card-img-top product-image" src="@Url.Content("~/Images/" + product.ImageUrl)" alt="@product.ProductName">

                <div class="card-body">
                    <h5 class="card-title">@product.ProductName</h5>
                    <p class="card-text text-muted">
                        @(product.Description.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)
                    </p>
                    <p><strong>Цена:</strong> @product.Price лв.</p>
                    <p><strong>Наличност:</strong> @product.Availability бр.</p>

                    <div class="d-flex flex-column">
                        <a asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-primary mb-2">Детайли</a>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@product.ProductId" class="d-flex">
                                <input type="number" name="quantity" value="1" min="1" class="form-control text-center me-2" style="max-width: 70px;">
                                <button type="submit" class="btn btn-success flex-grow-1">Добави в количката</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
