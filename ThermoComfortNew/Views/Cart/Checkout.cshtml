@model CheckoutViewModel

<head>
    <link href="~/css/CheckoutPage.css" rel="stylesheet" />
</head>

@{
    ViewData["Title"] = "Checkout";
}

<h2>Checkout</h2>

@if (Model.CartItems.Any())
{
    <div id="cart">
        <div id="cart-header">Your Cart</div>

        @foreach (var item in Model.CartItems)
        {
            <div class="cart-item">
                @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                {
                    <img src="@Url.Content("~/Images/" + item.Product.ImageUrl)" alt="@item.Product.ProductName" class="product-image" />
                }
                else
                {
                    <span>No Image</span>
                }
                <div class="product-details">
                    <div class="product-title">@item.Product.ProductName</div>
                    <div class="product-price">@item.Product.Price.ToString("C")</div>
                    <div class="product-duration">Quantity: @item.Quantity</div>
                </div>
            </div>
        }

        <div id="total">
            <strong>Total Price:</strong> @Model.TotalPrice.ToString("C")
            <p>Debug Total Price: @Model.TotalPrice</p> <!-- Debugging -->
        </div>

        <h3>Детайли за поръчката</h3>
        <form asp-action="Checkout" method="post" class="checkout-form">
            <input type="hidden" asp-for="TotalPrice" /> <!-- Ensure TotalPrice is sent -->

            <div class="form-group">
                <label for="Address">Адрес</label>
                <textarea asp-for="Address" class="form-control" required placeholder="Въведете адрес"></textarea>
            </div>

            <div class="form-group">
                <label for="PhoneNumber">Телефонен номер</label>
                <input asp-for="PhoneNumber" class="form-control" required placeholder="Въведете телефонен номер" />
            </div>

            <button type="submit" class="checkout-btn">Place Order</button>
        </form>
    </div>
}
else
{
    <div class="alert alert-warning">
        Вашата количка е празна! Моля, добавете продукти преди да продължите към завършване на поръчката.
    </div>
}
