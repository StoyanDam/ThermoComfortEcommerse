@model List<ThermoComfortNew.Domain.Cart>

<h2>Checkout</h2>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td> <!-- Replace with product name if available -->
                    <td>@item.Quantity</td>
                    <td>@item.Price</td> <!-- Replace with actual product price -->
                    <td>@(item.Quantity * item.Price)</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-right">
        <h4>Total: @Model.Sum(item => item.Quantity * item.Price)</h4>
    </div>

    <form asp-action="ConfirmCheckout" method="post">
        <div class="form-group">
            <label for="phoneNumber">Phone Number</label>
            <input type="text" name="phoneNumber" class="form-control" required />
        </div>
        <div class="form-group">
            <label for="address">Address</label>
            <input type="text" name="address" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-success">Confirm Order</button>
    </form>
}
else
{
    <p>Your shopping cart is empty.</p>
    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
}