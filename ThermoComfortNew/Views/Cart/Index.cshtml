@model List<ThermoComfortNew.Domain.Cart>

<h2>Shopping Cart</h2>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price</td>
                    <td>@(item.Quantity * item.Price)</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-right">
        <h4>Total: @Model.Sum(item => item.Quantity * item.Price)</h4>
    </div>

    <a asp-action="Checkout" class="btn btn-success">Checkout</a>
}
else
{
    <p>Your shopping cart is empty.</p>
    <a asp-controller="Products" asp-action="All" class="btn btn-primary">Continue Shopping</a>
}