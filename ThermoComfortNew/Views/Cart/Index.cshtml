@model IEnumerable<ThermoComfortNew.Domain.ThermoComfortNew.Domain.ShoppingCartItem>

@{
    ViewData["Title"] = "Количка";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">🛒 Вашата количка</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }

    @if (TempData.ContainsKey("Message"))
    {
        <div class="alert alert-info text-center">
            @TempData["Message"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center p-4">
            <h4>Вашата количка е празна. 🛍️</h4>
            <a asp-controller="Products" asp-action="All" class="btn btn-primary mt-3">Продължи да пазаруваш</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle text-center">
                <thead class="bg-light">
                    <tr>
                        <th>Продукт</th>
                        <th>Цена</th>
                        <th>Количество</th>
                        <th>Крайна цена</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="d-flex align-items-center">
                                <img src="@Url.Content("~/images/" + item.Product.ImageUrl)" alt="Product Image" class="rounded me-2" style="width: 50px; height: 50px; object-fit: cover;">
                                <span>@item.Product.ProductName</span>
                            </td>
                            <td>@item.Product.Price лв</td>
                            <td>@item.Quantity</td>
                            <td><strong>@(item.Product.Price * item.Quantity) лв</strong></td>
                            <td>
                                <form asp-action="RemoveFromCart" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">❌ Премахни от количка</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <a asp-controller="Products" asp-action="All" class="btn btn-outline-primary">⬅ Продължи да пазаруваш</a>
            <a asp-action="Checkout" class="btn btn-success btn-lg">💳 Завърши поръчка</a>
        </div>
    }
</div>

