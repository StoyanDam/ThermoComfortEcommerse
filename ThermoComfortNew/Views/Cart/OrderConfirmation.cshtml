@model ThermoComfort.Data.Models.Order

<h2>Order Confirmation</h2>

<p>Thank you for your order! Your order has been placed successfully.</p>

<h4>Order Details</h4>
<ul>
    <li><strong>Order ID:</strong> @Model.Id</li>
    <li><strong>Order Date:</strong> @Model.OrderDate.ToString("g")</li>
    <li><strong>Delivery Date:</strong> @Model.DeliveryDate.ToString("g")</li>
    <li><strong>Total Price:</strong> @Model.TotalPrice</li>
</ul>

<a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Home</a>
