@model ThermoComfort.Data.Models.Order

<h2>Order Confirmation</h2>
<p>Thank you for your order!</p>
<p><strong>Order Number:</strong> @Model.Id</p>
<p><strong>Shipping Address:</strong> @Model.Address</p>
<p><strong>Total Amount:</strong> @Model.TotalPrice.ToString("C")</p>

<h4>Ordered Items</h4>
<ul>
    @foreach (var item in Model.OrderProducts)
    {
        <li>@item.Product.ProductName - @item.Quantity x @item.Product.Price.ToString("C")</li>
    }
</ul>

<a asp-action="Index" asp-controller="Home" class="btn btn-primary">Continue Shopping</a>
