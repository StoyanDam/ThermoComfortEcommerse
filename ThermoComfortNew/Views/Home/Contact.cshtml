@{
    ViewData["Title"] = "Contacts";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Свържи се с нас - ТермоКомфорт</title>
    <link rel="stylesheet" href="~/css/ContactPage.css">
</head>
<body>

    <section class="contact-form">
        <div class="container">
            <h2>Свържи се с нас</h2>
            <p>Имате въпроси или нужда от помощ? Свържете се с нас като попълните тази контактна форма и ние ще ви отговорим възможно най-скоро.</p>
            <form action="#" method="POST">
                <div class="form-group">
                    <label for="name">Име</label>
                    <input type="text" id="name" name="name" placeholder="Твоето име тук" required>
                </div>
                <div class="form-group">
                    <label for="email">Имейл</label>
                    <input type="email" id="email" name="email" placeholder="Твоят имейл тук" required>
                </div>
                <div class="form-group">
                    <label for="subject">Тема</label>
                    <input type="text" id="subject" name="subject" placeholder="Въведи тема" required>
                </div>
                <div class="form-group">
                    <label for="message">Съобщение</label>
                    <textarea id="message" name="message" placeholder="Твоето съобщение тук" rows="5" required></textarea>
                </div>
                <button type="submit" class="btn">Изпрати запитването</button>
            </form>
        </div>
    </section>
</body>
</html>