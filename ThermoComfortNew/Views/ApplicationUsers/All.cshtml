 @model IEnumerable<ThermoComfortNew.Domain.ApplicationUser>

@{
    ViewData["Title"] = "Потребители";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-users"></i> @ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-user-plus"></i> Добави потребител
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="custom-header">
                        <tr>
                            <th>Пълно име</th>
                            <th>Имейл</th>
                            <th>Телефон</th>
                            <th class="text-center">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@user.PhoneNumber</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-info btn-sm text-white">
                                        <i class="fas fa-eye"></i> Детайли
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-secondary btn-sm text-white">
                                        <i class="fas fa-edit"></i> Редактирай
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash-alt"></i> Изтрий
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
