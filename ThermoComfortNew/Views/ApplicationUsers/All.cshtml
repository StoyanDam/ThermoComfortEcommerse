@model IEnumerable<ThermoComfortNew.Domain.ApplicationUser>

@{
    ViewData["Title"] = "Потребители";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Добави потребител</a>
</p>
 
<table class="table">
    <thead>
        <tr>
            <th>Пълно име</th>
            <th>Имейл</th>
            <th>Телефон</th>
            <th>Действия</th>
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-info">Детайли</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-warning">Редактирай</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger">Изтрий</a>
               </td>
            </tr>
        }
    </tbody>
</table>
