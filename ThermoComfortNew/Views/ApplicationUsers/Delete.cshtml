@model ThermoComfortNew.Domain.ApplicationUser

@{
    ViewData["Title"] = "Изтрий потребител";
}

<h2>@ViewData["Title"]</h2>

<h3>Сигурни ли сте, че искате да изтриете този потребител?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Пълно име</dt>
        <dd class="col-sm-10">@Model.FullName</dd>

        <dt class="col-sm-2">Имейл</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Телефон</dt>
        <dd class="col-sm-10">@Model.PhoneNumber</dd>
    </dl>
</div>

<form method="post"  asp-action="Delete" >
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="All" class="btn btn-secondary">Назад към списъка</a>
</form>
