
 @model ThermoComfort.Data.Models.Order

@{
    ViewData["Title"] = "Изтриване на поръчка";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-danger text-white text-center">
                    <h3 class="mb-0">⚠️ Потвърждение за изтриване</h3>
                </div>
                <div class="card-body">
                    <h5 class="text-center mb-4">Сигурни ли сте, че искате да изтриете тази поръчка?</h5>

                    <div class="border rounded p-3">
                        <dl class="row">
                            <dt class="col-sm-4 fw-bold">Потребител:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.ApplicationUser.FullName)</dd>

                            <dt class="col-sm-4 fw-bold">Телефон:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.PhoneNumber)</dd>

                            <dt class="col-sm-4 fw-bold">Адрес:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Address)</dd>

                            <dt class="col-sm-4 fw-bold">Крайна цена:</dt>
                            <dd class="col-sm-8 text-success fw-bold">@Html.DisplayFor(model => model.TotalPrice) лв.</dd>

                            <dt class="col-sm-4 fw-bold">Дата на поръчка:</dt>
                            <dd class="col-sm-8">@Model.OrderDate.ToString("dd.MM.yyyy г. HH:mm")</dd>

                            <dt class="col-sm-4 fw-bold">Дата на доставка:</dt>
                            <dd class="col-sm-8">@Model.DeliveryDate.ToString("dd.MM.yyyy")</dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" class="mt-4 text-center">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="fas fa-trash-alt"></i> Изтрий
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-lg ms-2">
                            <i class="fas fa-arrow-left"></i> Отказ
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
