@model IEnumerable<ThermoComfort.Data.Models.Order>

@{
    ViewData["Title"] = "Моите поръчки";
}


<div class="container mt-4">
    <h1 class="text-center mb-4">Моите поръчки</h1>

    <div class="table-responsive">
        <table class="table table-hover table-bordered text-center">
            <thead class="custom-header">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.ApplicationUser.FullName)</th>
                    <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.TotalPrice)</th>
                    <th>@Html.DisplayNameFor(model => model.OrderDate)</th>
                    <th>@Html.DisplayNameFor(model => model.DeliveryDate)</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.ApplicationUser.FullName)</td>
                        <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                        <td>@Html.DisplayFor(modelItem => item.Address)</td>
                        <td class="fw-bold text-success">@Html.DisplayFor(modelItem => item.TotalPrice) лв.</td>
                        <td>@item.OrderDate.ToString("dd.MM.yyyy г. HH:mm")</td>
                        <td>@item.DeliveryDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2 ">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                        <i class="fas fa-edit text-white"></i> Промени
                                    </a>
                                }
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash-alt"></i> Откажи
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


