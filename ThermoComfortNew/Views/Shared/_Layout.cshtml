<!DOCTYPE html>
<html>
<head>

        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - ТермоКомфорт</title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="shortcut icon" type="image/x-icon" href="~/favicon.ico" />

        <!-- Включване на Font Awesome за икони -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    </head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logoTC.webp" alt="ThermoComfort Logo" class="logo">
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Начална страница</a>
                        </li>
                     
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Products" asp-action="All">Всички продукти</a>
                        </li>

                        <!-- Показва "Моите поръчки" само ако потребителят е влязъл в системата -->
                        @if (User.Identity.IsAuthenticated)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Orders" asp-action="Index">Моите поръчки</a>
                        </li>
                        }

                        <!-- Административно меню (само за администратори) -->
                        @if (this.User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle" role="button" aria-haspopup="true" aria-expanded="false">
                                    Администрация <span class="tf-ion-ios-arrow-down"></span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Продукти</a></li>
                                    <li><a class="dropdown-item" asp-controller="ApplicationUsers" asp-action="All">Потребители</a></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Категории</a></li>
                                  
                                </ul>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Contact">Контакти</a>
                        </li>
                    </ul>

                    <!-- Показва количката само ако потребителят е влязъл -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link text-light" asp-controller="Cart" asp-action="Index">
                            <i class="fas fa-shopping-cart"></i> Количка
                            <span class="badge bg-danger" id="cartCounter">(@ViewBag.CartCount)</span>
                        </a>
                    }

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="footer">
        <div class="container">
            <p>&copy; 2025 ТермоКомфорт. Всички права запазени.</p>
            <p>
                <a asp-controller="Home" asp-action="Contact">Свържете се с нас</a>|
                <span>Тел.: +359889235511</span>|
                <span>stoyan_dam@abv.bg</span> 
                
            </p>
        </div>
    </footer>

    <!-- Включване на JavaScript файлове -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

<!-- Скрипт за обновяване на броя продукти в количката -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        fetch('/Cart/GetCartCount')
            .then(response => response.json())
            .then(data => {
                document.getElementById("cartCounter").innerText = data.count;
            })
            .catch(error => console.error('Error fetching cart count:', error));
    });
</script>

</html>

